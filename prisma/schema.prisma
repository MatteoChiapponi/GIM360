generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  OWNER
  TRAINER
  RECEPTIONIST
}

enum GymStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
}

enum StudentFileType {
  FICHA
  APTO_MEDICO
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

// ─── Modelos ─────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  role           UserRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner   Owner?
  trainer Trainer?
}

model Owner {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  gyms Gym[]
}

model Gym {
  id        String    @id @default(cuid())
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id])
  name      String
  address   String?
  phone     String?
  status    GymStatus @default(ACTIVE)
  createdAt DateTime  @default(now())

  trainers      Trainer[]
  students      Student[]
  groups        Group[]
  fixedExpenses FixedExpense[]
  payments      Payment[]
  cashClosings  CashClosing[]
  studentFiles  StudentFile[]
  attendances   Attendance[]

  @@index([ownerId])
}

model FixedExpense {
  id        String   @id @default(cuid())
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([gymId])
}

model Trainer {
  id           String       @id @default(cuid())
  userId       String?      @unique
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  gymId        String
  gym          Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name         String
  active       Boolean      @default(true)
  startedAt    DateTime?
  createdAt    DateTime     @default(now())

  groups TrainerGroup[]

  @@index([gymId])
}

model Student {
  id                   String           @id @default(cuid())
  gymId                String
  gym                  Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  firstName            String
  lastName             String
  birthDate            DateTime?
  nationalId           String?
  phone1               String
  phone2               String?
  emergencyPhone       String?
  emergencyContact     String?
  joinedAt             DateTime         @default(now())
  leftAt               DateTime?
  status               StudentStatus    @default(ACTIVE)
  trialEndsAt          DateTime?
  dueDay               Int              @default(1)
  createdAt            DateTime         @default(now())

  groups   StudentGroup[]
  payments Payment[]
  files    StudentFile[]

  @@index([gymId])
}

model Group {
  id           String   @id @default(cuid())
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name         String
  monthlyPrice Decimal  @db.Decimal(10, 2)
  maxCapacity  Int?
  createdAt    DateTime @default(now())

  trainers    TrainerGroup[]
  students    StudentGroup[]
  schedules   Schedule[]
  attendances Attendance[]

  @@index([gymId])
}

model TrainerGroup {
  id         String   @id @default(cuid())
  trainerId  String
  trainer    Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  hourlyRate Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  schedules TrainerGroupSchedule[]

  @@unique([trainerId, groupId])
  @@index([groupId])
}

model TrainerGroupSchedule {
  id             String       @id @default(cuid())
  trainerGroupId String
  trainerGroup   TrainerGroup @relation(fields: [trainerGroupId], references: [id], onDelete: Cascade)
  weekDay        DayOfWeek
  startTime      String // "HH:MM"
  endTime        String // "HH:MM"
  createdAt      DateTime     @default(now())

  @@unique([trainerGroupId, weekDay])
  @@index([trainerGroupId])
}

model StudentGroup {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([studentId, groupId])
  @@index([groupId])
}

model Schedule {
  id          String      @id @default(cuid())
  groupId     String
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  weekDays    DayOfWeek[]
  startTime   String // format "HH:MM"
  endTime     String // format "HH:MM"
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime    @default(now())

  @@index([groupId])
}

model Payment {
  id            String         @id @default(cuid())
  gymId         String
  gym           Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Restrict)
  period        DateTime       // first day of the month: 2026-04-01T00:00:00Z
  amount        Decimal        @db.Decimal(10, 2)
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  paidAt        DateTime?
  verified      Boolean        @default(false)
  cashClosingId String?
  cashClosing   CashClosing?   @relation(fields: [cashClosingId], references: [id], onDelete: SetNull)
  notes         String?
  createdAt     DateTime       @default(now())

  @@unique([studentId, period])
  @@index([gymId, period, status])
  @@index([cashClosingId])
}

model StudentFile {
  id          String          @id @default(cuid())
  studentId   String
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gymId       String
  gym         Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  fileType    StudentFileType
  fileName    String
  storagePath String
  mimeType    String
  sizeBytes   Int
  uploadedAt  DateTime        @default(now())

  @@index([studentId])
  @@index([gymId])
}

model CashClosing {
  id                 String   @id @default(cuid())
  gymId              String
  gym                Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  fromDate           DateTime // paidAt of earliest payment
  toDate             DateTime // paidAt of latest payment
  closedAt           DateTime @default(now())
  totalCollected     Decimal  @db.Decimal(10, 2)
  paidCount          Int
  cashCount          Int      @default(0)
  cashTotal          Decimal  @db.Decimal(10, 2) @default(0)
  transferCount      Int      @default(0)
  transferTotal      Decimal  @db.Decimal(10, 2) @default(0)
  cardCount          Int      @default(0)
  cardTotal          Decimal  @db.Decimal(10, 2) @default(0)
  notes              String?
  createdAt          DateTime @default(now())

  payments Payment[]

  @@index([gymId])
}

model Attendance {
  id            String   @id @default(cuid())
  gymId         String
  gym           Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date          DateTime
  detail        Json?
  takenByUserId String?
  takenByName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([groupId, date])
  @@index([gymId, date])
}
